# MufYard Backend - Railway Environment Variables

APP_NAME=MufYARD-V2
DEBUG=False
PORT=8000

# Security
SECRET_KEY=your_very_secret_key_here_generate_one
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# Firebase (Copy content from your serviceAccountKey.json)
FIREBASE_SERVICE_ACCOUNT_JSON={"type": "service_account", ...}

# Gemini AI
GOOGLE_API_KEY=your_gemini_api_key

# Database / Sync
STARTUP_SYNC_ENABLED=False
DATA_DIR=/app/data
